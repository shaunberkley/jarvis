# Jarvis env template. Copy to .env for local dev. Set as Fly secrets in production.

# Claude auth — copy Bob's OAuth token so Jarvis shares the Claude Max subscription
CLAUDE_OAUTH_TOKEN=

# Telegram bot (create one via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Fireflies
FIREFLIES_API_KEY=
FIREFLIES_WEBHOOK_SECRET=

# Gmail (OAuth credentials from Google Cloud Console)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Google Calendar
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=

# Linear
LINEAR_API_KEY=

# Supabase (personal project)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Zep (cloud free tier first; self-host fallback later)
ZEP_API_KEY=

# Browserbase
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# LinkedIn persistent context (created once via a Browserbase live session
# after you manually log into LinkedIn). See docs/SETUP.md step 10.
LINKEDIN_CONTEXT_ID=

# Optional intervals (defaults: scout 1h, inbox 10m, zep 5m)
# SCOUT_INTERVAL_MS=
# INBOX_INTERVAL_MS=
# ZEP_INTERVAL_MS=

# Optional kill switches
# JARVIS_CRON=off
# JARVIS_NOTIFY=off
